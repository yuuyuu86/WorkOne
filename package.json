{
  "name": "workone",
  "version": "0.1.0",
  "description": "連絡・学校・予定系サービスをまとめて見るための連絡専用ブラウザー",
  "main": "dist-electron/main.js",
  "author": "WorkOne",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "vite",
    "icons": "node scripts/gen-icons.mjs",
    "dist": "npm run icons && npm run build && electron-builder",
    "dist:dir": "npm run icons && npm run build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.workone.app",
    "productName": "WorkOne",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "現在地の天気を表示するために位置情報を使用します。",
        "NSLocationUsageDescription": "現在地の天気を表示するために位置情報を使用します。"
      },
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Network",
      "target": [
        "AppImage"
      ]
    }
  }
}
